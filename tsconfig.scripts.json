{
  "extends": "./tsconfig.base.json",

  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["node"],

    // For `/config/default.js`
    "allowJs": true,
    "checkJs": true,

    "rootDir": "./",
    "tsBuildInfoFile": ".tsbuildcache/scripts.tsbuildinfo",
  },

  "include": ["global.d.ts", "src/scripts/**/*"],

  "exclude": ["node_modules", "**/*.tsx"],
}
