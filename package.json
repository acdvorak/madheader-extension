    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "prettier-plugin-curly": "^0.4.1",
    "raw-loader": "^4.0.2",
    "resolve-tspaths": "^0.8.23",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "type-fest": "^5.6.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.60.0",
    "user-agent-data-types": "^0.4.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "web-ext": "^10.5.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.35.3": true,
    "unrs-resolver@1.12.2": true,
    "protobufjs@7.6.5": true
  },
  "overrides": {
    "uuid": "$uuid",
    "undici": "$undici",
    "js-yaml": "$js-yaml",
    "postcss": "$postcss",
    "form-data": "$form-data",
    "dompurify": "$dompurify",
    "typescript": "$typescript"
  }
}
