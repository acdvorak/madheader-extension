  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.6",
    "@eslint/core": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@mui/types": "^9.0.0",
    "@prettier/sync": "^0.6.1",
