{
  "name": "chrome-madheader-extension",
  "version": "0.9.0",
  "author": {
    "name": "Andrew C. Dvorak",
    "email": "andy@andydvorak.net"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "--------------------------------------------------------------": "",
    "clean": "rimraf dist/ out/ .tsbuildcache/ .eslintcache",
    "dev": "tsx src/scripts/dev.ts",
    "dev:firefox": "web-ext run --source-dir=dist/firefox --devtools",
    "build": "tsx src/scripts/build.ts",
    "---------------------------------------------------------------": "",
    "check": "npm run typecheck && npm run lint && npm test",
    "test": "vitest run",
    "typecheck": "tsc --build --noEmit tsconfig.json",
    "lint": "eslint --cache",
    "lint:fix": "npm run format",
    "lint:firefox": "web-ext lint --source-dir=dist/firefox",
    "format": "npm-run-all format:prettier format:eslint format:prettier",
    "format:prettier": "prettier --write .",
    "format:eslint": "eslint --cache --fix",
    "----------------------------------------------------------------": ""
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
