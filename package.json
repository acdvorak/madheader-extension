    "deepmerge-ts": "^7.1.5",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "fast-diff": "^1.3.0",
    "fast-equals": "^6.0.0",
    "fast-json-stable-stringify": "^2.1.0",
    "form-data": "^4.0.6",
    "https-proxy-agent": "^9.1.0",
    "js-yaml": "^5.2.1",
    "jsonc-parser": "^3.3.1",
    "just-debounce-it": "^3.2.0",
    "lodash": "^4.18.1",
    "markdown-it": "^14.3.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
