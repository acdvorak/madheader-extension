    "@monaco-editor/react": "^4.8.0-rc.3",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@opentf/std": "^0.13.0",
    "@svgr/webpack": "^8.1.0",
