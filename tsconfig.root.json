{
  "extends": "./tsconfig.base.json",

  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,

    "rootDir": "./",
    "tsBuildInfoFile": ".tsbuildcache/root.tsbuildinfo",
  },

  "include": ["*.ts", "*.mts"],
}
